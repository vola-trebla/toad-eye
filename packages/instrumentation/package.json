{
  "name": "toad-eye",
  "version": "2.11.2",
  "description": "Observability for MCP servers and LLM applications — traces, metrics, dashboards. One-line instrumentation for OpenAI, Anthropic, Gemini, and MCP. Self-hosted with Grafana + Prometheus + Jaeger.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./alerts": {
      "types": "./dist/alerts/index.d.ts",
      "import": "./dist/alerts/index.js",
      "default": "./dist/alerts/index.js"
    },
    "./drift": {
      "types": "./dist/drift/index.d.ts",
      "import": "./dist/drift/index.js",
      "default": "./dist/drift/index.js"
    },
    "./export": {
      "types": "./dist/export.d.ts",
      "import": "./dist/export.js",
      "default": "./dist/export.js"
    },
    "./vercel": {
      "types": "./dist/vercel.d.ts",
      "import": "./dist/vercel.js",
      "default": "./dist/vercel.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js",
      "default": "./dist/mcp/index.js"
    }
  },
  "bin": {
    "toad-eye": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "grep -q 'toad-eye' README.md || { echo '❌ README.md is missing or broken'; exit 1; } && npm run build && npm pack --dry-run 2>&1 | grep -q 'README.md' || { echo '❌ README.md not in tarball'; exit 1; }"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vola-trebla/toad-eye"
  },
  "homepage": "https://github.com/vola-trebla/toad-eye#readme",
  "readmeFilename": "README.md",
  "author": "albertalov",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "mcp-observability",
    "mcp-monitoring",
    "opentelemetry",
    "llm",
    "instrumentation",
    "observability",
    "tracing",
    "metrics",
    "grafana",
    "openai",
    "anthropic",
    "gemini",
    "cost-tracking",
    "auto-instrumentation",
    "gen-ai",
    "ai-agent",
    "tool-calling",
    "budget-guards",
    "finops",
    "streaming",
    "jaeger",
    "prometheus"
  ],
  "license": "ISC",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "yaml": "^2.7.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "@google/generative-ai": ">=0.20.0",
    "nodemailer": ">=8.0.0",
    "openai": ">=4.0.0",
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "nodemailer": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "vitest": "^4.1.0"
  }
}
