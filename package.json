{
  "name": "toad-eye-monorepo",
  "version": "2.0.0",
  "description": "OpenTelemetry-based observability toolkit for LLM systems",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/instrumentation",
    "packages/server",
    "demo"
  ],
  "scripts": {
    "build": "npm run build --workspace=packages/instrumentation",
    "test": "npm run test --workspace=packages/instrumentation",
    "demo": "npm run dev --workspace=demo",
    "load": "npm run load --workspace=demo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:dashboards": "npx tsx scripts/validate-dashboards.ts",
    "prepare": "husky"
  },
  "author": "albertalov",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write"
  }
}
